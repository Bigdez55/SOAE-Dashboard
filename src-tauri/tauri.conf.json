{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --port 5173",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "SOAE Dashboard",
    "version": "1.0.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "SOAE Dashboard",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["app", "dmg", "msi", "nsis"],
      "identifier": "com.transdev.soae.dashboard"
    }
  }
}
